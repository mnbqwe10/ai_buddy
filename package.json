{
  "name": "ai-buddy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && node scripts/build-extension.mjs && node scripts/verify-extension-build.mjs",
    "dev": "node scripts/build-extension.mjs --watch",
