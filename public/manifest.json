{
  "manifest_version": 3,
  "name": "AI Buddy",
  "version": "1.2.1",
  "version_name": "1.2.1-dev4",
  "description": "Scenario-based AI sidebar actions for selected browser text.",
  "icons": {
    "64": "logo.png"
  },
  "permissions": [
    "storage",
    "sidePanel",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://chat.deepseek.com/*",
    "https://web.whatsapp.com/*",
    "https://web.telegram.org/*",
    "https://discord.com/*",
    "https://copilot.microsoft.com/*",
    "https://m365.cloud.microsoft/*"
  ],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "AI Buddy",
    "default_popup": "popup.html",
    "default_icon": "logo.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://chat.deepseek.com/*"
      ],
      "js": ["assets/aiChatBridge.js"],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "matches": ["https://copilot.microsoft.com/*", "https://m365.cloud.microsoft/*"],
      "js": ["assets/copilotBridge.js"],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://web.whatsapp.com/*",
        "https://web.telegram.org/*",
        "https://discord.com/*"
      ],
      "js": ["assets/messagingBridge.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-toolbar-enabled": {
      "suggested_key": {
        "default": "Ctrl+Shift+1",
        "mac": "MacCtrl+Shift+1"
      },
      "description": "Enable or disable AI Buddy toolbar"
    },
    "toggle-sidebar": {
      "suggested_key": {
        "default": "Ctrl+Shift+2",
        "mac": "MacCtrl+Shift+2"
      },
      "description": "Open AI Buddy side panel"
    },
    "capture-screenshot": {
      "suggested_key": {
        "default": "Ctrl+Shift+3",
        "mac": "MacCtrl+Shift+3"
      },
      "description": "Start AI Buddy screenshot capture"
    },
    "cycle-scenario": {
      "suggested_key": {
        "default": "Ctrl+Shift+4",
        "mac": "MacCtrl+Shift+4"
      },
      "description": "Cycle AI Buddy Scenario"
    }
  }
}
